<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>YARD VORTEX — Home Energy Waste Finder</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg: #ffffff;
      --bg-secondary: #f5f5f3;
      --border: rgba(0,0,0,0.12);
      --border-md: rgba(0,0,0,0.25);
      --text: #1a1a1a;
      --text-secondary: #666660;
      --text-tertiary: #999993;
      --radius-md: 8px;
      --radius-lg: 12px;
      --green: #3B6D11;
      --green-bg: #EAF3DE;
      --red: #993C1D;
      --red-bg: #FAECE7;
      --amber: #854F0B;
      --amber-bg: #FAEEDA;
    }
    @media (prefers-color-scheme: dark) {
      :root {
        --bg: #1c1c1a;
        --bg-secondary: #252523;
        --border: rgba(255,255,255,0.12);
        --border-md: rgba(255,255,255,0.25);
        --text: #f0efe8;
        --text-secondary: #999993;
        --text-tertiary: #666660;
        --green: #97C459;
        --green-bg: #173404;
        --red: #F0997B;
        --red-bg: #4A1B0C;
        --amber: #FAC775;
        --amber-bg: #412402;
      }
    }
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: var(--bg-secondary); color: var(--text); min-height: 100vh; }
    .app { max-width: 900px; margin: 0 auto; padding: 2rem 1rem; }
    .header { margin-bottom: 1.5rem; }
    .header h1 { font-size: 26px; font-weight: 600; letter-spacing: -0.02em; }
    .header p { font-size: 14px; color: var(--text-secondary); margin-top: 6px; }
    .rate-row { display: flex; align-items: center; gap: 10px; margin-bottom: 1.25rem; font-size: 13px; color: var(--text-secondary); flex-wrap: wrap; }
    .rate-row input, .rate-row select { height: 34px; padding: 0 10px; font-size: 13px; background: var(--bg); border: 0.5px solid var(--border-md); border-radius: var(--radius-md); color: var(--text); }
    .rate-row input { width: 80px; }
    .rate-row select { width: 200px; }
    .tabs { display: flex; gap: 0; margin-bottom: 1.5rem; border-bottom: 1px solid var(--border); }
    .tab { padding: 9px 18px; font-size: 14px; color: var(--text-secondary); cursor: pointer; border: none; background: none; border-bottom: 2px solid transparent; margin-bottom: -1px; transition: color 0.15s; }
    .tab.active { color: var(--text); font-weight: 500; border-bottom-color: var(--text); }
    .tab:hover:not(.active) { color: var(--text); }
    .panel { display: none; }
    .panel.active { display: block; }
    .metrics { display: grid; grid-template-columns: repeat(4, minmax(0,1fr)); gap: 10px; margin-bottom: 1.25rem; }
    .metric { background: var(--bg); border: 0.5px solid var(--border); border-radius: var(--radius-md); padding: 14px 16px; }
    .metric-label { font-size: 12px; color: var(--text-secondary); margin-bottom: 4px; }
    .metric-value { font-size: 22px; font-weight: 600; }
    .card { background: var(--bg); border: 0.5px solid var(--border); border-radius: var(--radius-lg); padding: 1.1rem 1.25rem; margin-bottom: 1rem; }
    .card-title { font-size: 14px; font-weight: 500; margin-bottom: 14px; }
    .add-row { display: grid; grid-template-columns: 2fr 1.1fr 0.75fr 0.75fr 0.75fr auto; gap: 8px; align-items: center; }
    @media (max-width: 640px) { .add-row { grid-template-columns: 1fr 1fr; } .metrics { grid-template-columns: 1fr 1fr; } }
    select, input[type=text], input[type=number] { width: 100%; height: 36px; padding: 0 10px; font-size: 13px; background: var(--bg); border: 0.5px solid var(--border-md); border-radius: var(--radius-md); color: var(--text); }
    select:focus, input:focus { outline: 2px solid rgba(100,100,100,0.3); outline-offset: 1px; }
    .btn { height: 36px; padding: 0 16px; font-size: 13px; cursor: pointer; border: 0.5px solid var(--border-md); border-radius: var(--radius-md); background: transparent; color: var(--text); white-space: nowrap; transition: background 0.12s; }
    .btn:hover { background: var(--bg-secondary); }
    .btn.primary { background: var(--text); color: var(--bg); border-color: var(--text); }
    .btn.primary:hover { opacity: 0.85; }
    .btn.danger { color: var(--red); border-color: transparent; background: transparent; font-size: 18px; padding: 0; width: 36px; }
    .btn.danger:hover { background: var(--red-bg); border-radius: var(--radius-md); }
    .appliance-header { display: grid; grid-template-columns: 2fr 0.8fr 0.6fr 0.6fr 0.8fr 0.8fr 0.55fr 36px; gap: 8px; padding: 4px 0 10px; font-size: 11px; color: var(--text-secondary); font-weight: 500; text-transform: uppercase; letter-spacing: 0.05em; }
    .appliance-row { display: grid; grid-template-columns: 2fr 0.8fr 0.6fr 0.6fr 0.8fr 0.8fr 0.55fr 36px; gap: 8px; align-items: center; padding: 9px 0; border-top: 0.5px solid var(--border); font-size: 13px; }
    .rank-item { display: flex; align-items: center; gap: 14px; padding: 11px 0; border-top: 0.5px solid var(--border); }
    .rank-num { font-size: 20px; font-weight: 600; color: var(--text-tertiary); min-width: 28px; text-align: center; }
    .rank-bar-wrap { flex: 1; }
    .rank-name { font-size: 14px; font-weight: 500; }
    .rank-room { font-size: 12px; color: var(--text-secondary); margin-left: 6px; font-weight: 400; }
    .rank-bar { height: 6px; border-radius: 3px; background: var(--border); margin-top: 5px; overflow: hidden; }
    .rank-fill { height: 100%; border-radius: 3px; }
    .rank-fill.high { background: #D85A30; }
    .rank-fill.mid { background: #BA7517; }
    .rank-fill.low { background: #639922; }
    .rank-standby { font-size: 11px; color: #993C1D; margin-top: 3px; }
    .rank-meta { font-size: 13px; color: var(--text-secondary); min-width: 180px; text-align: right; line-height: 1.6; }
    .swap-item { display: flex; gap: 12px; align-items: flex-start; padding: 11px 14px; background: var(--bg-secondary); border-radius: var(--radius-md); margin-bottom: 8px; }
    .swap-icon { font-size: 18px; margin-top: 1px; }
    .swap-text { font-size: 13px; line-height: 1.6; }
    .swap-save { font-weight: 600; color: var(--green); }
    .sim-header { display: grid; grid-template-columns: 2fr 1fr 1fr; gap: 8px; padding-bottom: 8px; font-size: 11px; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.05em; }
    .sim-row { display: grid; grid-template-columns: 2fr 1fr 1fr; gap: 8px; align-items: center; padding: 11px 0; border-top: 0.5px solid var(--border); font-size: 13px; }
    .sim-result { text-align: right; font-weight: 500; }
    .sim-result.save { color: var(--green); }
    .sim-total-card { display: flex; justify-content: space-between; align-items: baseline; padding: 14px 18px; background: var(--green-bg); border: 0.5px solid var(--border); border-radius: var(--radius-lg); }
    .sim-total-label { font-size: 14px; color: var(--text-secondary); }
    .sim-total-value { font-size: 22px; font-weight: 600; color: var(--green); }
    .badge { display: inline-block; padding: 2px 9px; border-radius: 4px; font-size: 11px; font-weight: 600; }
    .badge-high { background: var(--red-bg); color: var(--red); }
    .badge-mid { background: var(--amber-bg); color: var(--amber); }
    .badge-low { background: var(--green-bg); color: var(--green); }
    .empty { text-align: center; padding: 2.5rem; color: var(--text-tertiary); font-size: 14px; }
    input[type=range] { width: 100%; accent-color: var(--text); }
  </style>
</head>
<body>
<div class="app">
  <div class="header">
    <h1>Phantom Load — Home Energy Waste Finder</h1>
    <p>Discover hidden electricity costs, appliance by appliance</p>
  </div>

  <div class="rate-row">
    <span>Electricity rate:</span>
    <input type="number" id="rate" value="7" min="1" max="30" step="0.5">
    <span>₹/unit (kWh)</span>
    <span style="margin-left:8px">Region:</span>
    <select id="region">
      <option value="0.82">India average (0.82 kg CO₂/kWh)</option>
      <option value="0.71">South India (0.71)</option>
      <option value="0.94">North India (0.94)</option>
      <option value="0.45">Hydro-heavy region (0.45)</option>
    </select>
  </div>

  <div class="tabs">
    <button class="tab active" onclick="showTab('inventory',this)">Inventory</button>
    <button class="tab" onclick="showTab('ranking',this)">Waste ranking</button>
    <button class="tab" onclick="showTab('swaps',this)">Swap &amp; save</button>
    <button class="tab" onclick="showTab('simulator',this)">What-if simulator</button>
  </div>

  <!-- INVENTORY -->
  <div id="tab-inventory" class="panel active">
    <div class="card">
      <div class="card-title">Add appliance</div>
      <div class="add-row">
        <select id="add-cat" onchange="onCatChange()">
          <option value="">— select from catalog —</option>
          <option value="AC (1.5 ton)|1500">AC (1.5 ton) · 1500W</option>
          <option value="AC (2 ton)|2000">AC (2 ton) · 2000W</option>
          <option value="Refrigerator|150">Refrigerator · 150W</option>
          <option value="Washing Machine|500">Washing Machine · 500W</option>
          <option value="Microwave|1200">Microwave · 1200W</option>
          <option value="TV LED 43\"|100">TV LED 43" · 100W</option>
          <option value="TV LED 55\"|150">TV LED 55" · 150W</option>
          <option value="Set-top Box|20">Set-top Box · 20W</option>
          <option value="Laptop|65">Laptop · 65W</option>
          <option value="Desktop PC|300">Desktop PC · 300W</option>
          <option value="Monitor|40">Monitor · 40W</option>
          <option value="WiFi Router|10">WiFi Router · 10W</option>
          <option value="Ceiling Fan|75">Ceiling Fan · 75W</option>
          <option value="LED Bulb|9">LED Bulb · 9W</option>
          <option value="CFL Bulb|23">CFL Bulb · 23W</option>
          <option value="Incandescent Bulb|60">Incandescent Bulb · 60W</option>
          <option value="Geyser|2000">Geyser · 2000W</option>
          <option value="Iron|1000">Iron · 1000W</option>
          <option value="Mixer/Grinder|750">Mixer/Grinder · 750W</option>
          <option value="Phone Charger|5">Phone Charger · 5W</option>
          <option value="Gaming Console|150">Gaming Console · 150W</option>
          <option value="Custom|0">Custom...</option>
        </select>
        <input type="text" id="add-name" placeholder="Custom name" style="display:none">
        <input type="number" id="add-watts" placeholder="Watts" min="1">
        <input type="number" id="add-hours" placeholder="Hrs/day" min="0.1" max="24" step="0.5" value="4">
        <select id="add-standby">
          <option value="0">No standby</option>
          <option value="5">Low standby (5W)</option>
          <option value="15">Med standby (15W)</option>
          <option value="30">High standby (30W)</option>
        </select>
        <select id="add-room">
          <option>Living room</option>
          <option>Bedroom</option>
          <option>Kitchen</option>
          <option>Study</option>
          <option>Bathroom</option>
          <option>Other</option>
        </select>
        <button class="btn primary" onclick="addAppliance()">+ Add</button>
      </div>
    </div>

    <div class="card">
      <div class="card-title">Your appliances</div>
      <div class="appliance-header">
        <span>Appliance</span><span>Room</span><span>Watts</span><span>Hrs/day</span><span>₹/month</span><span>CO₂/yr (kg)</span><span>Score</span><span></span>
      </div>
      <div id="appliance-rows"></div>
    </div>

    <div class="metrics">
      <div class="metric"><div class="metric-label">Monthly cost</div><div class="metric-value" id="m-cost">₹0</div></div>
      <div class="metric"><div class="metric-label">Annual cost</div><div class="metric-value" id="m-annual">₹0</div></div>
      <div class="metric"><div class="metric-label">kWh / month</div><div class="metric-value" id="m-kwh">0</div></div>
      <div class="metric"><div class="metric-label">CO₂ / year (kg)</div><div class="metric-value" id="m-co2">0</div></div>
    </div>
  </div>

  <!-- RANKING -->
  <div id="tab-ranking" class="panel">
    <div class="card">
      <div class="card-title">Appliances ranked by waste score</div>
      <div id="rank-list"><div class="empty">Add appliances in the Inventory tab first</div></div>
    </div>
  </div>

  <!-- SWAPS -->
  <div id="tab-swaps" class="panel">
    <div class="card">
      <div class="card-title">Swap &amp; save recommendations</div>
      <div id="swap-list"><div class="empty">Add appliances to get personalised recommendations</div></div>
    </div>
  </div>

  <!-- SIMULATOR -->
  <div id="tab-simulator" class="panel">
    <div class="card">
      <div class="card-title">What-if simulator — adjust usage and see projected savings</div>
      <div class="sim-header"><span>Appliance</span><span>Reduce by (hrs/day)</span><span style="text-align:right">Annual saving</span></div>
      <div id="sim-rows"><div class="empty">Add appliances to simulate savings</div></div>
    </div>
    <div class="sim-total-card">
      <span class="sim-total-label">Total projected annual saving</span>
      <span class="sim-total-value" id="sim-total">₹0 · 0 kg CO₂</span>
    </div>
  </div>
</div>

<script>
  let appliances = [
    { id:1, name:'AC (1.5 ton)', room:'Bedroom', watts:1500, hours:8, standby:5 },
    { id:2, name:'Refrigerator', room:'Kitchen', watts:150, hours:24, standby:0 },
    { id:3, name:'TV LED 55"', room:'Living room', watts:150, hours:5, standby:15 },
    { id:4, name:'Set-top Box', room:'Living room', watts:20, hours:5, standby:30 },
    { id:5, name:'Ceiling Fan', room:'Bedroom', watts:75, hours:10, standby:0 },
    { id:6, name:'Incandescent Bulb', room:'Living room', watts:60, hours:6, standby:0 },
    { id:7, name:'Geyser', room:'Bathroom', watts:2000, hours:1, standby:0 },
    { id:8, name:'Desktop PC', room:'Study', watts:300, hours:6, standby:15 },
    { id:9, name:'WiFi Router', room:'Living room', watts:10, hours:24, standby:0 },
  ];
  let nextId = 10;
  let simReductions = {};

  const getRate = () => parseFloat(document.getElementById('rate').value) || 7;
  const getEF = () => parseFloat(document.getElementById('region').value) || 0.82;

  function calc(a) {
    const rate = getRate(), ef = getEF();
    const activeKwh = a.watts * a.hours / 1000;
    const standbyKwh = a.standby * (24 - a.hours) / 1000;
    const totalKwh = activeKwh + standbyKwh;
    const monthKwh = totalKwh * 30;
    const yearKwh = totalKwh * 365;
    const monthCost = monthKwh * rate;
    const yearCost = yearKwh * rate;
    const yearCo2 = yearKwh * ef;
    const standbyPct = totalKwh > 0 ? standbyKwh / totalKwh : 0;
    const score = Math.round(yearCost * 0.5 + yearCo2 * 0.3 + standbyPct * 1000 * 0.2);
    return { activeKwh, standbyKwh, totalKwh, monthKwh, yearKwh, monthCost, yearCost, yearCo2, standbyPct, score };
  }

  function badge(score) {
    if (score > 5000) return '<span class="badge badge-high">High</span>';
    if (score > 1500) return '<span class="badge badge-mid">Medium</span>';
    return '<span class="badge badge-low">Low</span>';
  }

  function fmt(n) { return Math.round(n).toLocaleString('en-IN'); }

  function renderAll() {
    renderInventory(); renderMetrics(); renderRanking(); renderSwaps(); renderSimulator();
  }

  function renderInventory() {
    const el = document.getElementById('appliance-rows');
    if (!appliances.length) { el.innerHTML = '<div class="empty">No appliances yet — add one above</div>'; return; }
    el.innerHTML = appliances.map(a => {
      const c = calc(a);
      return `<div class="appliance-row">
        <span style="font-weight:500">${a.name}</span>
        <span style="color:var(--text-secondary)">${a.room}</span>
        <span>${a.watts}W</span>
        <span>${a.hours}h</span>
        <span>₹${fmt(c.monthCost)}</span>
        <span>${fmt(c.yearCo2)}</span>
        <span>${badge(c.score)}</span>
        <button class="btn danger" onclick="remove(${a.id})">×</button>
      </div>`;
    }).join('');
  }

  function renderMetrics() {
    let mc=0, yc=0, mk=0, yco2=0;
    appliances.forEach(a => { const c=calc(a); mc+=c.monthCost; yc+=c.yearCost; mk+=c.monthKwh; yco2+=c.yearCo2; });
    document.getElementById('m-cost').textContent = '₹'+fmt(mc);
    document.getElementById('m-annual').textContent = '₹'+fmt(yc);
    document.getElementById('m-kwh').textContent = fmt(mk);
    document.getElementById('m-co2').textContent = fmt(yco2);
  }

  function renderRanking() {
    const el = document.getElementById('rank-list');
    if (!appliances.length) { el.innerHTML = '<div class="empty">Add appliances in the Inventory tab first</div>'; return; }
    const sorted = [...appliances].map(a=>({a,c:calc(a)})).sort((x,y)=>y.c.score-x.c.score);
    const max = sorted[0].c.score;
    el.innerHTML = sorted.map(({a,c},i)=>{
      const pct = Math.round(c.score/max*100);
      const cls = pct>65?'high':pct>35?'mid':'low';
      return `<div class="rank-item">
        <div class="rank-num">${i+1}</div>
        <div class="rank-bar-wrap">
          <div class="rank-name">${a.name}<span class="rank-room">${a.room}</span></div>
          <div class="rank-bar"><div class="rank-fill ${cls}" style="width:${pct}%"></div></div>
          ${c.standbyPct>0.15?`<div class="rank-standby">Standby drain: ${Math.round(c.standbyPct*100)}% of total usage</div>`:''}
        </div>
        <div class="rank-meta">₹${fmt(c.yearCost)}/yr<br>${fmt(c.yearCo2)} kg CO₂</div>
      </div>`;
    }).join('');
  }

  function renderSwaps() {
    const el = document.getElementById('swap-list');
    const swaps = [];
    appliances.forEach(a => {
      const c = calc(a);
      if (a.name.includes('Incandescent')) {
        const s=(a.watts-9)*a.hours/1000*365*getRate(), co2=(a.watts-9)*a.hours/1000*365*getEF();
        swaps.push({icon:'💡',text:`Replace ${a.name} (${a.watts}W) with a 9W LED bulb`,save:s,co2});
      }
      if (a.name.includes('CFL')) {
        const s=(a.watts-9)*a.hours/1000*365*getRate(), co2=(a.watts-9)*a.hours/1000*365*getEF();
        swaps.push({icon:'💡',text:`Replace ${a.name} (${a.watts}W) with a 9W LED bulb`,save:s,co2});
      }
      if (a.standby>0 && c.standbyKwh*365*getRate()>200) {
        const s=c.standbyKwh*365*getRate(), co2=c.standbyKwh*365*getEF();
        swaps.push({icon:'🔌',text:`Unplug ${a.name} completely when not in use — eliminate standby draw`,save:s,co2});
      }
      if (a.name.includes('AC') && a.hours>5) {
        const s=a.watts*1/1000*365*getRate(), co2=a.watts*1/1000*365*getEF();
        swaps.push({icon:'❄️',text:`Reduce ${a.name} usage by 1 hour/day (e.g. set to 26°C instead of 24°C)`,save:s,co2});
      }
      if (a.name.includes('Geyser')) {
        const s=a.watts*0.25/1000*365*getRate(), co2=a.watts*0.25/1000*365*getEF();
        swaps.push({icon:'🚿',text:`Reduce ${a.name} heating by 15 min/day`,save:s,co2});
      }
      if (a.name.includes('Desktop')) {
        const s=(a.watts-65)*a.hours/1000*365*getRate()*0.5, co2=(a.watts-65)*a.hours/1000*365*getEF()*0.5;
        swaps.push({icon:'💻',text:`Use a laptop instead of ${a.name} for half your sessions`,save:s,co2});
      }
    });
    if (!swaps.length) { el.innerHTML = '<div class="empty">Add appliances to get personalised recommendations</div>'; return; }
    swaps.sort((a,b)=>b.save-a.save);
    el.innerHTML = swaps.map(s=>`<div class="swap-item">
      <div class="swap-icon">${s.icon}</div>
      <div class="swap-text">${s.text} — <span class="swap-save">saves ₹${fmt(s.save)}/yr and ${fmt(s.co2)} kg CO₂</span></div>
    </div>`).join('');
  }

  function renderSimulator() {
    const el = document.getElementById('sim-rows');
    if (!appliances.length) { el.innerHTML = '<div class="empty">Add appliances to simulate savings</div>'; return; }
    el.innerHTML = appliances.map(a => {
      const c = calc(a);
      const rid = 'r'+a.id;
      if (!(rid in simReductions)) simReductions[rid] = 0;
      const red = simReductions[rid];
      const max = Math.min(a.hours, 10);
      const saveCost = a.watts*red/1000*365*getRate();
      const saveCo2 = a.watts*red/1000*365*getEF();
      return `<div class="sim-row">
        <div>${a.name}<br><span style="font-size:11px;color:var(--text-secondary)">${a.hours}h/day · ₹${fmt(c.yearCost)}/yr</span></div>
        <div>
          <input type="range" min="0" max="${max}" step="0.5" value="${red}" oninput="updateSim('${rid}',this.value,'${a.id}')">
          <div style="font-size:11px;color:var(--text-secondary);margin-top:2px" id="lbl-${rid}">${red>0?'−'+red+'h/day':'No change'}</div>
        </div>
        <div class="sim-result${red>0?' save':''}" id="res-${rid}">${red>0?'−₹'+fmt(saveCost)+' · −'+fmt(saveCo2)+'kg':'—'}</div>
      </div>`;
    }).join('');
    updateSimTotal();
  }

  function updateSim(rid, val, aid) {
    simReductions[rid] = parseFloat(val);
    const a = appliances.find(a=>a.id==aid);
    if (!a) return;
    const red = parseFloat(val);
    const saveCost = a.watts*red/1000*365*getRate();
    const saveCo2 = a.watts*red/1000*365*getEF();
    const lbl = document.getElementById('lbl-'+rid);
    const res = document.getElementById('res-'+rid);
    if (lbl) lbl.textContent = red>0?'−'+red+'h/day':'No change';
    if (res) { res.textContent = red>0?'−₹'+fmt(saveCost)+' · −'+fmt(saveCo2)+'kg':'—'; res.className='sim-result'+(red>0?' save':''); }
    updateSimTotal();
  }

  function updateSimTotal() {
    let tc=0, tco2=0;
    appliances.forEach(a=>{ const red=simReductions['r'+a.id]||0; tc+=a.watts*red/1000*365*getRate(); tco2+=a.watts*red/1000*365*getEF(); });
    const el = document.getElementById('sim-total');
    if (el) el.textContent = '₹'+fmt(tc)+' · '+fmt(tco2)+' kg CO₂';
  }

  function addAppliance() {
    const cat = document.getElementById('add-cat').value;
    const nameInput = document.getElementById('add-name').value.trim();
    const watts = parseFloat(document.getElementById('add-watts').value);
    const hours = parseFloat(document.getElementById('add-hours').value);
    const standby = parseInt(document.getElementById('add-standby').value);
    const room = document.getElementById('add-room').value;
    let name = cat && cat !== 'Custom|0' ? cat.split('|')[0] : nameInput;
    if (!name || !watts || !hours) { alert('Please fill in all fields.'); return; }
    appliances.push({ id:nextId++, name, room, watts, hours, standby });
    saveToStorage();
    renderAll();
  }

  function remove(id) {
    appliances = appliances.filter(a=>a.id!==id);
    delete simReductions['r'+id];
    saveToStorage();
    renderAll();
  }

  function showTab(name, btn) {
    document.querySelectorAll('.tab').forEach(t=>t.classList.remove('active'));
    document.querySelectorAll('.panel').forEach(p=>p.classList.remove('active'));
    btn.classList.add('active');
    document.getElementById('tab-'+name).classList.add('active');
    renderAll();
  }

  function onCatChange() {
    const cat = document.getElementById('add-cat').value;
    const nameInput = document.getElementById('add-name');
    const wattsInput = document.getElementById('add-watts');
    if (cat === 'Custom|0') { nameInput.style.display='block'; wattsInput.value=''; }
    else if (cat) { nameInput.style.display='none'; wattsInput.value=cat.split('|')[1]; }
    else { nameInput.style.display='none'; }
  }

  function saveToStorage() {
    try { localStorage.setItem('phantom-appliances', JSON.stringify(appliances)); localStorage.setItem('phantom-nextid', nextId); } catch(e) {}
  }

  function loadFromStorage() {
    try {
      const saved = localStorage.getItem('phantom-appliances');
      const sid = localStorage.getItem('phantom-nextid');
      if (saved) { appliances = JSON.parse(saved); nextId = parseInt(sid)||10; }
    } catch(e) {}
  }

  document.getElementById('rate').addEventListener('input', renderAll);
  document.getElementById('region').addEventListener('input', renderAll);

  loadFromStorage();
  renderAll();
</script>
</body>
</html>
